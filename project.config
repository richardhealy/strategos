# strategos - blueprint toggles
# Consumed by setup-project.sh. Off pieces are simply not scaffolded.
PROJECT_NAME=strategos
DB=postgres            # program state model lives here
GOOGLE_AUTH=true       # dashboard sign-in (leadership audience)
STRIPE=false           # not a paid SaaS in v1
EMAIL=true             # transactional mail for HITL notifications + escalations
SENTRY=true            # error tracking (watchtower handles deep observability)
ANALYTICS=false
DEPLOY=railway         # persistent multi-integration sync workers + durable routines
VISIBILITY=public      # portfolio showcase
ORG=
