# ---- Core ----
NODE_ENV=development
DATABASE_URL=postgresql://strategos:strategos@localhost:5432/strategos?schema=public

# ---- LLM (planning + communication) ----
ANTHROPIC_API_KEY=
STRATEGOS_MODEL=claude-sonnet-4-6
# Optional: route spend through abacus / resilience through bulwark (AI Gateway)
AI_GATEWAY_URL=

# ---- Durable runtime (Inngest) ----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Auth (dashboard) ----
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Transactional email ----
RESEND_API_KEY=
EMAIL_FROM=strategos@example.com

# ---- Error tracking ----
SENTRY_DSN=

# ---- Integrations ----
# Linear
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=
LINEAR_TEAM_KEYS=       # comma-separated team keys to sync (e.g. ENG,OPS); empty = all teams
# Jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=
# GitHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
# GitLab
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=
# Azure DevOps
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_WEBHOOK_SECRET=
